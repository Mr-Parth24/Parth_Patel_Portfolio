# Daily footer quote (optional)
# If set, your GET endpoint is tried first. A `day=YYYY-MM-DD` query is appended for cache-friendly daily rotation.
# JSON shapes supported: { "quote": "...", "author": "..." } | { "content": "...", "author": "..." } | [ { "q": "...", "a": "..." } ] (ZenQuotes)
# VITE_DAILY_QUOTE_URL=https://your-worker.workers.dev/api/quote
# VITE_DAILY_QUOTE_API_KEY=
